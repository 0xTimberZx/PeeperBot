# ── PeeperBot / prdt-bot configuration ──────────────────────────────────────
# Copy to .env (this workspace or the repo root) and adjust. Every value has a
# safe default; LIVE trading is OFF unless you explicitly enable it below.

# --- market ---
# Binance symbols traded on PRDT (PRDT settles on the Binance feed). Comma-separated.
PRDT_SYMBOLS=BTCUSDT
# Cross-asset signal feed (NOT traded — CORE isn't offered on PRDT; it's the
# market-health gate for spike-fade). Set to NONE to disable.
SIGNAL_SYMBOL=COREUSDT
# PRDT Pro round window in minutes (1–30). Also the backtest settle horizon.
# 15 is the sweep-proven best on real BTC data (58% win / +10.2% ROI/trade);
# 5m LOSES under real entries, 30m is +5.9%. Re-run `sweep` on your own data.
PRDT_TIMEFRAME_MIN=15
# Fixed PRDT Pro payout multiplier (win returns stake × payout).
PRDT_PAYOUT=1.9

# --- strategy ---
STRATEGY=spike-fade
# Only act on signals at/above this confidence (0–1). Higher = more selective.
CONFIDENCE_FLOOR=0.6
# Restrict trading to one side: UP (buy/long only), DOWN (sell/short only), or
# blank for both. In a trending market one side carries a drift tailwind. The
# backtest always prints a UP-vs-DOWN breakdown so you can see which side pays.
# TRADE_SIDE=UP

# spike-fade knobs (all optional; tune from `profile`/`sweep` output):
# SPIKE_MIN_Z=2.0            # min |displacement| in vol units to call a spike
# SPIKE_STALL_BARS=2         # bars the peak must be old before entry (anti-chase)
# SPIKE_MAX_VOL_RATIO=3.0    # stand down if post-peak vol > this × baseline

# Regime-adaptive expiry (OFF by default). When true, each trade gets a per-round
# expiry from the current vol regime. NOTE: on real BTC data so far, FLAT 15m beat
# adaptive — leave off unless a regime-split test proves it adds value. Defaults
# below avoid the sub-breakeven 5m window.
# ADAPTIVE_EXPIRY=false
# EXPIRY_HIGH_VOL=10         # expiry (min) when current vol is in its high tercile
# EXPIRY_MID_VOL=15
# EXPIRY_LOW_VOL=20
# Live loop cadence, seconds.
POLL_SECONDS=30
# Paper/real stake per trade, in the chain's bet currency units.
STAKE=1
# Where the append-only trade journal is written.
JOURNAL_PATH=./data/journal.jsonl
# Optional local fixture to use when the live feed is unavailable.
BACKTEST_FIXTURE_PATH=./candles.json

# --- price feed source ---
# PRDT settles on Binance, but Binance.com returns HTTP 451 (geo-block) from US
# clouds like GitHub Codespaces. The feed auto-falls-through this chain — set the
# primary and the ordered fallbacks (comma list). Options: binance, okx, bybit.
# All three carry BTC and CORE; majors agree to the cent across venues.
FEED_SOURCE=binance
FEED_FALLBACKS=okx,bybit

# --- alerts (console is always on; these are optional) ---
TELEGRAM_BOT_TOKEN= 8551333445:AAFx_T4QYmnKM8JfLBOFOPFeepW454zbuIU
TELEGRAM_CHAT_ID= 8726225587
DISCORD_WEBHOOK_URL=

# --- CORE-bottom watch (`peeperbot watch`) ---
# Alerts you to hunt a BTC reversal (UP) when CORE drops toward its multi-month
# floor. The floor = average of the K lowest daily pivot lows over the lookback.
WATCH_LOOKBACK_DAYS=200          # daily candles used to find the pivot-low band
WATCH_PIVOT_STRENGTH=3           # bars each side that define a pivot low
WATCH_K_LOWEST=5                 # average the 3 or 5 lowest pivots into the band
WATCH_PROXIMITY_PCT=0.06         # alert when CORE is within this % above the band
WATCH_DROP_PCT=0.05              # require a "drastic" CORE drop of at least this %
WATCH_DROP_WINDOW_HRS=24         # ...measured over this many hours
WATCH_MARKET_WIDE_BTC_DROP=0.01  # BTC also down > this % => market-wide washout
# Optional fixed hard-support line. 0 = disabled (default): the pivot band is the
# primary, auto-adjusting floor, so nothing goes stale when CORE makes new lows.
CORE_HARD_SUPPORT=0
WATCH_POLL_SECONDS=300
WATCH_BAND_REFRESH_MIN=240

# --- Regime monitor (`peeperbot regime`) ---
# Mixes BrokerForce volatility-regime shifts with new Core/BTC/ratio highs & lows.
REGIME_LOOKBACK_DAYS=200          # daily candles fetched per asset
REGIME_EXTREME_DAYS=90            # a "new high/low" is vs this many days
REGIME_DELTA_Z=1.0                # BrokerForce vol z-move between checks = sizeable
REGIME_POLL_SECONDS=900           # macro cadence (15 min); it only alerts on change

# --- BrokerForce read-only volatility overlay (optional) ---
# A READ-ONLY Postgres connection to BrokerForce's database. Nothing is ever
# written. Leave blank to disable the overlay entirely.
BROKERFORCE_DATABASE_URL=
# |z-score| above which current volatility counts as "extreme vs norm".
BROKERFORCE_EXTREME_Z=2.0
# Advanced: override if BrokerForce's price-history schema differs.
# BROKERFORCE_PRICE_TABLE=asset_price_hourly
# BROKERFORCE_SYMBOL_COL=symbol
# BROKERFORCE_PRICE_COL=price
# BROKERFORCE_TIME_COL=ts

# --- LIVE TRADING (DANGER: real funds) ─────────────────────────────────────
# All must be set AND LIVE_TRADING=true before any real trade is placed. The
# on-chain executor is a guarded stub until you wire the PRDT contract — see
# src/execution.ts.
LIVE_TRADING=false
PRDT_PRIVATE_KEY=
PRDT_RPC_URL=
PRDT_CONTRACT_ADDRESS=
PRDT_CHAIN_ID=56
# Hard safety caps (per trade / per day) in stake currency units.
MAX_STAKE_PER_TRADE=5
MAX_STAKE_PER_DAY=25
