# ── PeeperBot / prdt-bot configuration ──────────────────────────────────────
# Copy to .env (this workspace or the repo root) and adjust. Every value has a
# safe default; LIVE trading is OFF unless you explicitly enable it below.

# --- market ---
# Binance symbols traded on PRDT (PRDT settles on the Binance feed). Comma-separated.
PRDT_SYMBOLS=BTCUSDT
# Cross-asset signal feed (NOT traded — CORE isn't offered on PRDT; it's the
# market-health gate for spike-fade). Set to NONE to disable.
SIGNAL_SYMBOL=COREUSDT
# PRDT Pro round window in minutes (1–30). Also the backtest settle horizon.
# 30 is the base: gives spike reversions (sweet spot ~16–23 min) room to finish.
PRDT_TIMEFRAME_MIN=30
# Fixed PRDT Pro payout multiplier (win returns stake × payout).
PRDT_PAYOUT=1.9

# --- strategy ---
STRATEGY=spike-fade
# Only act on signals at/above this confidence (0–1). Higher = more selective.
CONFIDENCE_FLOOR=0.6
# Live loop cadence, seconds.
POLL_SECONDS=30
# Paper/real stake per trade, in the chain's bet currency units.
STAKE=1
# Where the append-only trade journal is written.
JOURNAL_PATH=./data/journal.jsonl
# Optional local fixture to use when the live feed is unavailable.
BACKTEST_FIXTURE_PATH=./candles.json

# --- price feed source ---
# PRDT settles on Binance, but Binance.com returns HTTP 451 (geo-block) from US
# clouds like GitHub Codespaces. The feed auto-falls-through this chain — set the
# primary and the ordered fallbacks (comma list). Options: binance, okx, bybit.
# All three carry BTC and CORE; majors agree to the cent across venues.
FEED_SOURCE=binance
FEED_FALLBACKS=okx,bybit

# --- alerts (console is always on; these are optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# --- BrokerForce read-only volatility overlay (optional) ---
# A READ-ONLY Postgres connection to BrokerForce's database. Nothing is ever
# written. Leave blank to disable the overlay entirely.
BROKERFORCE_DATABASE_URL=
# |z-score| above which current volatility counts as "extreme vs norm".
BROKERFORCE_EXTREME_Z=2.0
# Advanced: override if BrokerForce's price-history schema differs.
# BROKERFORCE_PRICE_TABLE=asset_price_hourly
# BROKERFORCE_SYMBOL_COL=symbol
# BROKERFORCE_PRICE_COL=price
# BROKERFORCE_TIME_COL=ts

# --- LIVE TRADING (DANGER: real funds) ─────────────────────────────────────
# All must be set AND LIVE_TRADING=true before any real trade is placed. The
# on-chain executor is a guarded stub until you wire the PRDT contract — see
# src/execution.ts.
LIVE_TRADING=false
PRDT_PRIVATE_KEY=
PRDT_RPC_URL=
PRDT_CONTRACT_ADDRESS=
PRDT_CHAIN_ID=56
# Hard safety caps (per trade / per day) in stake currency units.
MAX_STAKE_PER_TRADE=5
MAX_STAKE_PER_DAY=25
